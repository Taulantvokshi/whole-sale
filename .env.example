# --- Postgres ---
# Render: use the *internal* URL in prod (no SSL). Locally use the *external*
# URL (contains render.com -> SSL is auto-enabled).
DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Firebase Admin ---
# Service-account JSON, base64-encoded (avoids newline/quoting issues):
#   cat service-account.json | base64
FIREBASE_SERVICE_ACCOUNT=base64_encoded_service_account_json

# --- Shopify app credentials (from your Shopify Partner dashboard) ---
SHOPIFY_API_KEY=your_api_key
SHOPIFY_API_SECRET=your_api_secret
# Comma-separated scopes you request from the merchant
SHOPIFY_SCOPES=read_products,write_products
# Shopify Admin API version
SHOPIFY_API_VERSION=2026-04

# --- URLs ---
# This server's public origin (used to build the Shopify redirect URI).
# Must match the "Allowed redirection URL" in your app settings.
HOST=http://localhost:3000
# Where the client app lives (buyer redirect target after connect/share).
CLIENT_URL=http://localhost:5173
PORT=3000
